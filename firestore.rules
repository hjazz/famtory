rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 사용자 본인만 읽기/쓰기/삭제
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // 가족 문서
    match /families/{familyId} {
      // 초대 코드 조회(joinFamily)를 위해 인증된 사용자 읽기 허용
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.memberIds;
      allow update: if request.auth != null
        && (request.auth.uid in resource.data.memberIds
            || request.auth.uid in request.resource.data.memberIds);
      // 마지막 멤버 계정 삭제 시 가족 문서 삭제 허용
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.memberIds;

      // 일기: 가족 멤버만 읽기/쓰기
      match /entries/{entryId} {
        function isFamilyMember() {
          return request.auth != null
            && request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.memberIds;
        }
        function isEntryOwner() {
          return request.auth != null && resource.data.userId == request.auth.uid;
        }

        allow read: if isFamilyMember();

        // 작성: 가족 멤버이며 userId가 본인이어야 함
        allow create: if isFamilyMember()
          && request.resource.data.userId == request.auth.uid;

        // 수정: reactions만 변경 허용 (content, userId, date 변경 불가)
        allow update: if isFamilyMember()
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.content == resource.data.content
          && request.resource.data.date == resource.data.date;

        // 삭제: 본인 일기만 삭제 가능
        allow delete: if isFamilyMember() && isEntryOwner();
      }
    }
  }
}
